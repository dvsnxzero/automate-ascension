# Copy this file to .env and fill in your real values
# NEVER commit .env to git

# Webull API (from https://www.webull.com/open-api-management)
WEBULL_APP_KEY=your_app_key_here
WEBULL_APP_SECRET=your_app_secret_here

# Database (Railway provides this automatically)
DATABASE_URL=postgresql://ascension:localdev@localhost:5432/ascension

# App Security
SECRET_KEY=change-me-to-a-random-64-character-string

# Environment (development | production)
ENVIRONMENT=development

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000
